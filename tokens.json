  "typography": {
    "fontFamily": "'Instrument Sans', sans-serif",
    "weights": {
      "regular": 400,
      "medium": 500,
      "semibold": 600,
      "bold": 700
    },
    "sizes": {
      "xxs": { "size": "0.6875rem", "lineHeight": "1rem", "px": 11 },
      "xs": { "size": "0.8125rem", "lineHeight": "1.3125rem", "px": 13 },
      "sm": { "size": "0.875rem", "lineHeight": "1.25rem", "px": 14 },
      "base": { "size": "1rem", "lineHeight": "1.5rem", "px": 16 },
      "lg": { "size": "1.125rem", "lineHeight": "1.75rem", "px": 18 },
      "xl": { "size": "1.3125rem", "lineHeight": "2rem", "px": 21 },
      "2xl": { "size": "1.75rem", "lineHeight": "2rem", "px": 28 },
      "3xl": { "size": "2rem", "lineHeight": "2rem", "px": 32 },
      "3.5xl": { "size": "2.5rem", "lineHeight": "3rem", "px": 40 },
      "4xl": { "size": "3rem", "lineHeight": "3.5rem", "px": 48 },
      "5xl": { "size": "3.5rem", "lineHeight": "3.75rem", "px": 56 },
      "6xl": { "size": "4rem", "lineHeight": "4rem", "px": 64 }
    },
    "letterSpacing": {
      "tight": "-0.025em",
      "tighter": "-0.05em"
    },
    "prose": {
      "body": "#727380",
      "headings": "#070A26",
      "links": "#070A26",
      "lead": "#727380"
    }
  },

  "spacing": {
    "0.5": "0.125rem",
    "1": "0.25rem",
    "1.5": "0.375rem",
    "2": "0.5rem",
    "3": "0.75rem",
    "4": "1rem",
    "5": "1.25rem",
    "6": "1.5rem",
    "8": "2rem",
    "10": "2.5rem",
    "12": "3rem",
    "14": "3.5rem",
    "16": "4rem",
    "20": "5rem",
    "24": "6rem",
    "32": "8rem"
  },

  "borderRadius": {
    "sm": "0.125rem",
    "DEFAULT": "0.25rem",
    "md": "0.375rem",
    "lg": "0.5rem",
    "xl": "0.75rem",
    "2xl": "1rem",
    "3xl": "1.5rem",
    "4xl": "2rem",
    "full": "9999px"
  },

  "shadows": {
    "sm": "0 1px 2px 0 rgb(0 0 0 / 0.05)",
    "DEFAULT": "0 1px 3px 0 rgb(0 0 0 / 0.1), 0 1px 2px -1px rgb(0 0 0 / 0.1)",
    "md": "0 4px 6px -1px rgb(0 0 0 / 0.1), 0 2px 4px -2px rgb(0 0 0 / 0.1)",
    "lg": "0 10px 15px -3px rgb(0 0 0 / 0.1), 0 4px 6px -4px rgb(0 0 0 / 0.1)",
    "xl": "0 25px 50px -12px rgb(0 0 0 / 0.25)",
    "drop": "drop-shadow(0px 20px 20px rgba(0, 0, 0, 0.1))"
  },

  "breakpoints": {
    "sm": "640px",
    "md": "768px",
    "lg": "1024px",
    "xl": "1280px",
    "2xl": "1280px"
  },

  "container": {
    "maxWidth": "1280px",
    "padding": {
      "DEFAULT": "1rem",
      "sm": "1rem",
      "md": "2rem",
      "lg": "2rem",
      "xl": "2rem",
      "2xl": "2rem"
    }
  },

  "transitions": {
    "durations": {
      "fast": "200ms",
      "default": "300ms",
      "medium": "500ms",
      "slow": "700ms"
    },
    "easing": {
      "default": "ease",
      "in": "ease-in",
      "out": "ease-out",
      "inOut": "ease-in-out",
      "collapse": "cubic-bezier(0.33, 1, 0.68, 1)"
    }
  },

  "effects": {
    "backdropBlur": {
      "sm": "blur(4px)",
      "DEFAULT": "blur(8px)"
    },
    "gradients": {
      "fadeToBlackTop": "linear-gradient(to bottom, #000, transparent)",
      "fadeToBlackBottom": "linear-gradient(to top, #000, transparent)",
      "horizontalDivider": "linear-gradient(to right, transparent, #EEF1F2, transparent)"
    },
    "glassMorphism": {
      "background": "rgba(255, 255, 255, 0.8)",
      "backdropFilter": "blur(8px)"
    }
  },

  "zIndex": {
    "base": 0,
    "content": 10,
    "overlay": 20,
    "header": 30,
    "modal": 40,
    "tooltip": 50
  },

  "components": {
    "button": {
      "borderRadius": "9999px",
      "padding": {
        "default": "0.875rem 1.25rem",
        "small": "0.5rem 1.25rem",
        "login": "0.5rem 1rem"
      },
      "fontWeight": 500,
      "variants": {
        "primary": { "bg": "#070A26", "text": "#FFFFFF" },
        "secondary": { "bg": "#FFFFFF", "text": "#070A26" },
        "outline": { "bg": "transparent", "text": "#070A26", "border": "1px solid #070A26" },
        "brainFreeze": { "bg": "#26DDFD", "text": "#070A26" },
        "brainFreezeDark": { "bg": "#20B3D2", "text": "#FFFFFF" },
        "capriSun": { "bg": "#FF5C00", "text": "#FFFFFF" },
        "capriSunDark": { "bg": "#CD4C08", "text": "#FFFFFF" },
        "mint": { "bg": "#CEFFC6", "text": "#070A26" },
        "mintDark": { "bg": "#A6CEA6", "text": "#FFFFFF" },
        "hotPink": { "bg": "#F1A7F2", "text": "#070A26" },
        "hotPinkDark": { "bg": "#C288C9", "text": "#FFFFFF" }
      }
    },
    "input": {
      "borderRadius": "0.375rem",
      "padding": "0.75rem 1rem",
      "border": "1px solid #CDCED4",
      "background": "#FFFFFF",
      "placeholder": "#9C9DA7",
      "states": {
        "focus": {
          "border": "#26DDFD",
          "ring": "0 0 0 2px rgba(38, 221, 253, 0.2)"
        },
        "error": { "border": "#EA5F5F" },
        "disabled": { "background": "#F3F3F4", "color": "#9C9DA7" }
      },
      "dark": {
        "background": "rgba(255, 255, 255, 0.2)",
        "border": "rgba(255, 255, 255, 0.2)",
        "text": "#FFFFFF",
        "focusRing": "#FFFFFF"
      }
    },
    "card": {
      "borderRadius": "0.75rem",
      "border": "1px solid #EEF1F2",
      "padding": "1.5rem",
      "imageHeight": "13rem"
    },
    "dropdown": {
      "borderRadius": "0.5rem",
      "padding": "0.75rem 0",
      "itemPadding": "0.5rem 1.5rem",
      "minWidth": "200px",
      "shadow": "lg"
    },
    "badge": {
      "padding": "0.5rem",
      "borderRadius": "0.25rem",
      "fontSize": "xxs",
      "textTransform": "uppercase"
    },
    "header": {
      "height": "auto",
      "logoHeight": "22px",
      "background": "rgba(255, 255, 255, 0.8)",
      "backdropFilter": "blur(8px)",
      "border": "1px solid #EEF1F2"
    },
    "progressBar": {
      "height": "2px",
      "background": "#070A26"
    },
    "checkbox": {
      "size": "1.25rem",
      "borderRadius": "0.375rem",
      "accentColor": "#26DDFD"
    }
  },

  "icons": {
    "sizes": {
      "xs": "12px",
      "sm": "16px",
      "md": "20px",
      "lg": "24px",
      "xl": "32px",
      "2xl": "48px"
    }
  }
}
